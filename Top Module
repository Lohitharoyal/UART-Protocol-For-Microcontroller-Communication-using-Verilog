module uart_top(
    input clk,
    input reset,
    input rx,
    input [7:0] tx_data,
    input tx_start,
    output tx
);

wire baud_tick;

baud_generator bg(
    .clk(clk),
    .reset(reset),
    .baud_tick(baud_tick)
);

uart_tx transmitter(
    .clk(clk),
    .baud_tick(baud_tick),
    .data_in(tx_data),
    .tx_start(tx_start),
    .tx(tx)
);

endmodule
